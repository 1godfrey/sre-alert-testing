# Copy this file to .env and adjust as needed.

# Host/port the FastAPI app binds to
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging level passed to uvicorn
LOG_LEVEL=info

# Path to the YAML file describing simulated endpoints
ENDPOINTS_CONFIG_PATH=config/endpoints.yaml

# Status code returned for a simulated endpoint when it doesn't
# specify its own error_status_code
DEFAULT_ERROR_STATUS_CODE=503

# Comma-separated list of origins allowed by CORS (for the React frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173
